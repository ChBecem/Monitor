rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable primitives
    function isValidId(id) {
      return id is string && id.size() >= 4 && id.size() <= 128 && id.matches('^[a-zA-Z0-9]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Session-specific robust validations to prevent updates from injecting harmful data shapes
    function isValidSession(data) {
      return data.id is string
        && data.id.size() <= 8
        && data.status is string
        && data.status.size() <= 64
        && data.babyDeviceName is string
        && data.babyDeviceName.size() <= 128
        && (data.batteryLevel == null || (data.batteryLevel >= 0 && data.batteryLevel <= 100))
        && (data.noiseLevel == null || (data.noiseLevel >= 0 && data.noiseLevel <= 150))
        && (data.isCrying == null || data.isCrying == true || data.isCrying == false)
        && (data.nightlightActive == null || data.nightlightActive == true || data.nightlightActive == false)
        && (data.nightlightColor == null || (data.nightlightColor is string && data.nightlightColor.size() <= 64))
        && (data.flashlightActive == null || data.flashlightActive == true || data.flashlightActive == false)
        && (data.activeLullaby == null || (data.activeLullaby is string && data.activeLullaby.size() <= 64))
        && (data.parentSpeaking == null || data.parentSpeaking == true || data.parentSpeaking == false)
        && (data.streamFrame == null || (data.streamFrame is string && data.streamFrame.size() <= 200000))
        && data.babyDeviceId is string
        && data.babyDeviceId.size() <= 128
        && (data.parentDeviceId == null || (data.parentDeviceId is string && data.parentDeviceId.size() <= 128))
        && (data.facingMode == null || (data.facingMode is string && data.facingMode.size() <= 32))
        && (data.streamQuality == null || (data.streamQuality is string && data.streamQuality.size() <= 32))
        && (data.updatedAt == null || (data.updatedAt is string && data.updatedAt.size() <= 64))
        && (data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 64));
    }

    // Sessions are paired strictly using a 4 to 6 digit alphanumeric ID
    match /sessions/{sessionId} {
      allow read: if isValidId(sessionId);
      allow create, update: if isValidId(sessionId) && isValidSession(incoming());
      allow delete: if isValidId(sessionId);
    }
  }
}
